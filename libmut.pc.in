prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include
datarootdir = ${prefix}/share
datadir=${prefix}/share

Name: libmut
Description: This holds various math utility functions I find useful in many programs.
URL: https://github.com/nicmcd/libmut
Version: 0.1.0
Requires: libprim
Libs: -L${libdir} -lmut 
Cflags: -I${includedir}
